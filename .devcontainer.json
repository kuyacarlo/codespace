{
  "name": "codespace-refactored",

  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },

  "remoteUser": "vscode",
  // "workspaceFolder": "/workspaces/codespace",

  "postCreateCommand": "bash postCreateCommand",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false // avoids trying to install docker-ce, just gives docker CLI
    },
    "ghcr.io/devcontainers-extra/features/act:1": {}
  }
}
